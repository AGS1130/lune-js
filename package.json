{
  "name": "@lune-js/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "lib",
      "packages/*"
    ],
    "catalog": {
      "clean-package": "2.2.0",
      "typescript": "6.0.3",
      "vite": "8.1.3",
      "vite-plugin-dts": "5.0.3"
    }
  },
  "scripts": {
    "build": "bun --filter '*' build",
    "lib": "bun run --cwd lib",
    "pkg:ctx": "bun run --cwd packages/context",
    "pkg:core": "bun run --cwd packages/core",
    "pkg:utils": "bun run --cwd packages/utils",
    "clean": "bun --filter '*' clean && rm -rf node_modules",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fresh": "bun clean && bun install",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "lefthook install",
    "changeset": "changeset",
    "version": "changeset version && node .changeset/postprocess-changelogs.cjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@happy-dom/global-registrator": "20.10.6",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
