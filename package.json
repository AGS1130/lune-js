{
  "name": "@lune-js/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "lib",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "bun --filter '*' build",
    "lib": "bun run --cwd lib",
    "pkg:ctx": "bun run --cwd packages/context",
    "pkg:core": "bun run --cwd packages/core",
    "pkg:utils": "bun run --cwd packages/utils",
    "clean": "bun --filter '*' clean && rm -rf node_modules",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fresh": "bun clean && bun install",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "husky install",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version && bun update && node .changeset/postprocess-changelogs.cjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@happy-dom/global-registrator": "20.10.6",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "bun lint"
  },
  "packageManager": "bun@1.3.14"
}
