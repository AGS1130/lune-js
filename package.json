{
  "name": "@lune-js/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "lib",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "bun --sequential --filter '*' build",
    "lib": "bun run --cwd lib",
    "clean": "bun --filter '*' clean && rm -rf node_modules",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "fresh": "bun clean && bun install",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "husky install",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version && bun update && node .changeset/postprocess-changelogs.cjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@happy-dom/global-registrator": "20.11.1",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "bun lint"
  },
  "packageManager": "bun@1.3.14"
}
