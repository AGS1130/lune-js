{
  "name": "lune-js",
  "version": "0.1.1",
  "description": "Simple, declarative, and functional library for building reactive user interfaces",
  "bugs": {
    "url": "https://github.com/AGS1130/lune-js/issues"
  },
  "license": "MIT",
  "author": "Gregory Salinas <ags1130@yahoo.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AGS1130/lune-js.git",
    "directory": "lib"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "unpkg": "dist/index.iife.js",
