    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@lune-js/context": "0.1.1",
    "@lune-js/core": "0.1.1",
    "@lune-js/utils": "0.1.1"
  },
  "devDependencies": {
    "clean-package": "2.2.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-dts": "5.0.3"
  }
}
