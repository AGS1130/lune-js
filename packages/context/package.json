{
  "name": "@lune-js/context",
  "version": "0.1.2",
  "description": "Optimized context library to manage state and behavior in Lune.js",
  "bugs": {
    "url": "https://github.com/AGS1130/lune-js/issues"
  },
  "license": "MIT",
  "author": "Gregory Salinas <ags1130@yahoo.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AGS1130/lune-js.git",
    "directory": "packages/context"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@lune-js/core": "0.1.2",
    "@lune-js/utils": "0.1.2"
  },
  "devDependencies": {
    "tsdown": "0.22.13",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": "^14.18.0 || >=16.10.0"
  }
}
