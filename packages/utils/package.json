{
  "name": "@lune-js/utils",
  "version": "0.1.0",
  "description": "Lower level utilities to build Lune.js",
  "bugs": {
    "url": "https://github.com/AGS1130/lune-js/issues"
  },
  "license": "MIT",
  "author": "Gregory Salinas <ags1130@yahoo.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AGS1130/lune-js.git",
    "directory": "packages/utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
