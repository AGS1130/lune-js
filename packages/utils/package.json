    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "es-toolkit": "1.49.0"
  },
  "devDependencies": {
    "clean-package": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
