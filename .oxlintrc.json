{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "import", "oxc", "typescript", "unicorn"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "rules": {
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error"
  },
  "env": {
    "builtin": true
  }
}
